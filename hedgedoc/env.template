# Simple environment details for PostgreSQL & HedgeDoc
# Use complex passwords and alternative account/db names from defaults.

# -----------------------------
# PostgreSQL Configuration
# -----------------------------
POSTGRES_USER=hedgedoc
POSTGRES_PASSWORD=password
POSTGRES_DB=hedgedoc

# -----------------------------
# HedgeDoc Configuration
# -----------------------------
#
# CMD_DOMAIN must be reachable from clients — use LAN IP or hostname
# e.g., 192.168.1.50 (not localhost unless using same machine)
#
CMD_DB_URL=postgres://hedgedoc:password@database:5432/hedgedoc
CMD_DOMAIN=localhost
CMD_URL_ADDPORT=true
