# ------------------------------------------------------------
# Minecraft Server Environment Template
#
# Copy this file to .env before starting the container:
#   cp env.template .env
# ------------------------------------------------------------

# Required to accept Minecraft's EULA (must be 'true' to run)
EULA=true

# Game difficulty: peaceful, easy, normal, hard
DIFFICULTY=normal

# Message of the Day (MOTD)
MOTD=Welcome to my server!

# Timezone
TZ=Europe/London

# Backup Directory
BACKUP_DIR=/PATH/TO/BACKUP_DIR/